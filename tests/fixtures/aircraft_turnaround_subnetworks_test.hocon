# Simple test case for telco_network_support agent network
# Tests basic network support inquiry handling
{
    # Describes what agent to test against
    "agent": "AirlineTurnaround/aircraft_traffic_controller",
    # "AirlineTurnaround/aircraft_traffic_controller",
    # "AirlineTurnaround/aircraft_turnaround",

    # Use direct sessions for external agents
    "use_direct": true,

    # Connect to the agent directly (no server required for testing)
    "connections": ["direct"], ## "http"

    # Notes on this configuration: 
    # "http" setting will enable connection thru the Neuro SAN http server that is running 
    # "direct"  will enable direct communication to the hocon provided that both AGENT_TOOL_PATH and AGENT_MANIFEST_FILE are properly set 
    # e.g. export AGENT_TOOL_PATH=path to agent tool path
    # e.g. export AGENT_MANIFEST_FILE=manifest.hocon path to manifest

    # Timeout for the entire test (5 minutes)
    "timeout_in_seconds": 3000,

    "success_ratio": "10/10", 

    # Interactions are a series of dictionaries with request elements paired with
    # descriptions of response checks
    // "interactions": [
    //     {
    //         # Simple network support inquiry
    //         "text": "We're experiencing network outages at our Boston office",

    //         # Test that the assistant responds by asking for more details
    //         "response": {
    //             "text": {
    //                 # The gist test checks if the response matches the general meaning
    //                 "gist": "The assistant should ask for additional details about the network issue such as the specific location address, type of network service (ethernet/optical), when the outage started, error messages, number of affected users, or service ID."
    //             }
    //         }
    //     }
    // ]

    "interactions": [
        {
            # This is what we send as input to streaming_chat()
            "text": "The B747 aircraft of flight AF84 is incoming. Execute the turnaround process.",

            # The response block treats how we are going to test what comes back
            "response": {
                # Text block says how we are going to examine the text of the response.
                // "text": {
                //     # Keywords says we are going to look for exact matches for each
                //     # element in a list of strings.  All elements need to show up
                //     # in order to pass.
                //     "gist": "flight number should be AF84"
                // }

                "sly_data": {

                    # Each key here corresponds to a key in the sly_data itself
                    # that is returned.
                    // "equals": {
                    "flight_number": {
                        # Value says we are going to look for exact values for each
                        # element in a list of strings.  All elements need to show up
                        # in order to pass.
                        // "aircraft_direction": [INCOMING]
                        "value": "AF85"
                        // 
                        // "flight_status": [APPROACH]
                        // "clearance_type": [CLEARED_FOR_LANDING]
                        // "assigned_runway_id": [19R]
                        // "assigned_runway_length": [2350 meters]
                        // "clearance_report": [The flight 'AF84' with aircraft type 'B747' is in 'APPROACH' status. It has been cleared for landing on runway '19R', which has a length of 2350 meters.]
                    },
                    "aircraft_type": {
                        "value": "B748"
                    }
                }

            }

            // "sly_data": {
            //     "x": 847,
            //     "y": 23
            // },

            # The response block treats how we are going to test what comes back
            // "response": {

            //     # Text block says how we are going to examine the text of the response.
            //     "sly_data": {

            //         # Each key here corresponds to a key in the sly_data itself
            //         # that is returned.
            //         // "equals": {
            //         "contains": {
            //             # Value says we are going to look for exact values for each
            //             # element in a list of strings.  All elements need to show up
            //             # in order to pass.
            //             // "aircraft_direction": [INCOMING]
            //             "flight_number": [AF85]
            //             // "aircraft_type": [B747]
            //             // "flight_status": [APPROACH]
            //             // "clearance_type": [CLEARED_FOR_LANDING]
            //             // "assigned_runway_id": [19R]
            //             // "assigned_runway_length": [2350 meters]
            //             // "clearance_report": [The flight 'AF84' with aircraft type 'B747' is in 'APPROACH' status. It has been cleared for landing on runway '19R', which has a length of 2350 meters.]
            //         }
            //     }
            // }

        }
    ]

}

// ** aircraft direction **: [aircraft_direction]
// ** flight number **: [flight_number]
// ** aircraft type **: [aircraft_type]
// ** flight status **: [flight_status]
// ** clearance type **: [clearance_type]
// ** assigned runway id **: [assigned_runway_id]
// ** assigned runway length **: [assigned_runway_length]
// ** clearance report **: [clearance_report]