        {
            "name": "aircraft_taxiing_agent",
            "function": {

                "description": """
I am the pilot in charge of taxiing the aircraft on the ground at the airport. 
                """
                "parameters": {
                    "type": "object", 
                    "properties": {
                        "flight_number": {
                            "type": "string", 
                            "description": "This is the flight number of the incoming aicraft."
                        },   
                        "aircraft_type": {
                            "type": "string", 
                            "description": "This is the type of the incoming aircraft."
                        },        
                        "flight_status": {
                            "type": "string", 
                            "description": "This is the status of the aircraft."
                        },        
                        "ground_clearance_type": {
                            "type": "string", 
                            "description": "This is the type of clearance given to the aircrfat."
                        },         
                        "ground_clearance_status": {
                            "type": "string", 
                            "description": "This is the status of clearance given to the aircraft."
                        },       
                        "assigned_runway_id": {
                            "type": "string", 
                            "description": "This is the runway assigned to the aircraft movement autorized by the clearance."
                        },        
                        "gate_id": {
                            "type": "string", 
                            "description": "This is the gate assigned to the aircraft parking."
                        },             
                        "gpu_readiness_status": {
                            "type": "string", 
                            "description": "This is the gpu readiness status."
                        },       
                        "chocks_readiness_status": {
                            "type": "string", 
                            "description": "This is the chocks readiness status."
                        },        
                    }, 
                    "required": ["flight_number", "aircraft_type","ground_clearance_type","ground_clearance_type","flight_status","assigned_runway_id","gate_id","gpu_readiness_status","chocks_readiness_status"] 
                },
            },
            "class": "aircraft_taxiing.execute_aircraft_taxiing" 
        }, 


#########
        {
            "name": "trackerAPI",
            "function": {

                "description": """
I am the flight tracker in charge of logging parameters during aircraft turnaround. 
I check passenger disembarkation status as passenger_disembarkation_status. 
I check crew exit status as crew_exit_status. 
I check baggage unload status as baggage_unload_status. 
                """

                "parameters": {
                    "type": "object", 
                    "properties": {
                        "flight_number": {
                            "type": "string", 
                            "description": "This is the flight number of the incoming aicraft."
                        },   
                        "aircraft_type": {
                            "type": "string", 
                            "description": "This is the type of the incoming aircraft."
                        },     
                        "flight_status": {
                            "type": "string", 
                            "description": "This is the flight status."
                        },          
                        "gate_id": {
                            "type": "string", 
                            "description": "This is the gate assigned to the aircraft parking."
                        },     
                        "ground_services_request_type": {
                            "type": "string", 
                            "description": "This is the type of the inquiry received for grand services."
                        },         
                        "wheels_chocks_readiness_status": {
                            "type": "string", 
                            "description": "This is the wheels chocks readiness status."
                        },   
                        "wheels_chocks_installation_status": {
                            "type": "string", 
                            "description": "This is the wheels chocks installation status."
                        },   
