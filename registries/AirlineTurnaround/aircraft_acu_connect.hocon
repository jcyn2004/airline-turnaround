{
    include "registries/aaosa_basic.hocon" 

    # Optional metadata describing this agent network
    "metadata": {
        "description": "Simple agent network using a single LLM-based agent",
        "tags": ["example"],
        "sample_queries": [
            "The B747 aircraft of flight AF84 is on blocks at gate A1. Engines are stopped and wheels chocks are installed. Connect the ACU.",
        ]
    },

    "llm_config": {
        "model_name": "gpt-4o",
    },
    "max_iterations": 40000, #3000 
    "max_execution_seconds": 7200, #600
    "commondefs": {
        "replacement_strings": {
            "instructions_prefix": """
You are part of aircraft turnaround process at an Airport. 
Only answer inquiries that are directly within your area of expertise.
Do not try to help for other matters.
Do not mention what you can NOT do. Only mention what you can do.
            """,
            "aaosa_instructions": """
When you receive an inquiry, you will:
1. If you are clearly not the right agent for this type of inquiry, reply you're not relevant.
2. If there is a chance you're relevant, call your down-chain agents to determine if they can answer all or part of the inquiry.
   Do not assume what your down-chain agents can do. Always call them. You'll be surprised.
3. Once all relevant down-chain agents have responded, either:
   - Analyze their response and compile your final response. No need to include non-relevant agents. In doubt, ask for clarification.
   - Follow up with your down-chain agents if needed, as many times as needed
   - If an action is needed, ask the most relevant down-chain agent to fulfill the inquiry.
4. Return the final response to the caller.
You may, in turn, be called by other agents in the system and have to act as a down-chain agent to them. 
            """
        },
        "replacement_values": {
            "aaosa_call": {
                "description": "Depending on the mode, returns a natural language string in response.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "inquiry": {
                            "type": "string",
                            "description": "The inquiry"
                        },
                        "mode": {
                            "type": "string",
                            "description": """
'Determine' to ask the agent if the inquiry belongs to it, in its entirety or in part.
'Fulfill' to ask the agent to fulfill the inquiry, if it can.
'Follow up' to ask the agent to respond to a follow up.
                            """
                        },
                    },
                    "required": [
                        "inquiry",
                        "mode"
                    ]
                }
            },
            "aaosa_command": """
If mode is 'Determine', return a json block with the following fields:
{
    "Name": <your name>,
    "Inquiry": <the inquiry>,
    "Mode": <Determine | Fulfill>,
    "Relevant": <Yes | No>,
    "Strength": <number between 1 and 10 representing how certain you are in your claim>,
    "Claim:" <All | Partial>,
    "Requirements" <None | list of requirements>
}
If mode is 'Fulfill' or "Follow up", respond to the inquiry and return a json block with the following fields:
{
    "Name": <your name>,
    "Inquiry": <the inquiry>,
    "Mode": Fulfill,
    "Response" <your response>
}
            """
        },
    },

    "tools": [

        {
            "name": "acu_connect_agent",
            "function": {
                "description": """
 I am in charge of connecting the acu unit to the aircraft at the gate. 
                """
                "parameters": {
                    "type": "object", 
                    "properties": {
                        "flight_number": {
                            "type": "string", 
                            "description": "This is the flight number of the incoming aicraft."
                        },   
                        "aircraft_type": {
                            "type": "string", 
                            "description": "This is the type of the incoming aircraft."
                        },         
                        "flight_status": {
                            "type": "string", 
                            "description": "This is the flight status."
                        },        
                        "gate_id": {
                            "type": "string", 
                            "description": "This is the gate where the aircraft is parked."
                        },       
                        "engines_stop_status": {
                            "type": "string", 
                            "description": "This is the status of engines stop."
                        },     
                        "wheels_chocks_installation_status": {
                            "type": "string", 
                            "description": "This is the status of wheels chocks installation."
                        },       
                        "acu_connection_status": {
                            "type": "string", 
                            "description": "This is the acu connection status."
                        },    
                    }, 
                    "required": ["flight_number", "aircraft_type","flight_status","gate_id","engines_stop_status","wheels_chocks_installation_status"] 
                }
            },
// {instructions_prefix}

// ,"engines_stop_status","wheels_chocks_installation_status"

//             "instructions": """
// You are the agent in charge of connecting acu to aircraft. 
// When you receive user inquiry to connect acu to aircraft: 
// 1. Determine engine stop status
// 2. Determine wheels chocks installation status. 
// 3. Make sure that aircraft engines are stopped and that wheels chocks are installed. 
//     a. Connect acu to aircraft 
//     b. report acu connect status. 
// """ ${aaosa_instructions},

//             "instructions": """
// You are the agent in charge of connecting acu to aircraft. 
// When user submit inquiry to connect acu to aircraft, proceed as follows: 
// 1. read the user inquiry and determine 
//     a. if flights status is on blocks, then flight_status = 'on blocks'
//     b. if engines stop status is stopped, then engines_stop_status = 'stopped'
//     c. if wheels chocks installation status is installed, then wheels_chocks_installation_status = 'installed'.
// 2. If engines_stop_status is not stopped or wheels_chucks_installation_status is not installed
//     a. call your tools to make sure that engines_stop_status is stopped and wheels_chucks_installation_status is installed
//     b. wait for their responses 
//     c. go back to step 2.  
// 3. If engines_stop_status = 'stopped' and wheels_chucks_installation_status = 'installed'
//     a. call acu_operator to connect acu to aircraft
//     b. Wait for its response and save it as acu_connection_status
//     c. Report acu_connection_status
// 4. Provide the acu connection status report summary as: 
//     ** acu connection status summary **: 
//     [acu_connection_status]
//             """ ${aaosa_instructions},

            "instructions": """
You are the agent in charge of connecting acu to aircraft. 
When user submit inquiry to connect acu to aircraft, proceed as follows: 
1. read the user inquiry and determine 
    a. if flights status is on blocks, then flight_status = 'on blocks'
    b. if engines stop status is stopped, then engines_stop_status = 'stopped'
    c. if wheels chocks installation status is installed, then wheels_chocks_installation_status = 'installed'.
2. Call trackerAPI
    a. wait for its response 
    b. store engines_stop_status as engines stop status and wheels_chucks_installation_status as wheels chucks installation status
3. If engines_stop_status is not stopped or wheels_chucks_installation_status is not installed
    a. call your tools to make sure that engines_stop_status is stopped and wheels_chucks_installation_status is installed
    b. wait for their responses 
    c. go back to step 2. 
4. Call trackerAPI
    a. wait for its response 
    b. store engines_stop_status as engines stop status and wheels_chucks_installation_status as wheels chucks installation status
5. If engines_stop_status = 'stopped' and wheels_chucks_installation_status = 'installed'
    a. call acu_operator to connect acu to aircraft
    b. Wait for its response and save it as acu_connection_status
    c. Report acu_connection_status
6. Provide the acu connection status report summary as: 
    ** acu connection status summary **: 
    [acu_connection_status]
            """ ${aaosa_instructions},

// Make sure that user provides engines stop status such as 'stopped' or 'running'. 
// Make sure that user provides wheels chucks installation status such as installed. 

            # Specify the sly data that should come back from the tools to the client.
            # The session is initiated by the tool, and the client must re-use it to continue the conversation.
            "allow": {
                "to_upstream": {
                    "sly_data": {
                        "acu_connection_status": true
                    }
                }
            },

            # Specify the sly data that should come back from the tools to the client.
            # The session is initiated by the tool, and the client must re-use it to continue the conversation.
            "allow": {
                "to_downstream": {
                    "sly_data": {
                        "acu_connection_status": true
                    }
                }
            },

            # Specify the sly data that should come back from the tools to the client.
            # The session is initiated by the tool, and the client must re-use it to continue the conversation.
            "allow": {
                "from_upstream": {
                    "sly_data": {
                        "flight_number": true
                        "aircraft_type": true
                        "flight_status": true
                        "gate_id": true 
                        "engines_stop_status": true
                        "wheels_chocks_installation_status": true
                        "acu_connection_status": true
                    }
                }
            },
            
            # Specify the sly data that should come back from the tools to the client.
            # The session is initiated by the tool, and the client must re-use it to continue the conversation.
            "allow": {
                "from_downstream": {
                    "sly_data": {
                        "flight_number": true
                        "aircraft_type": true
                        "flight_status": true
                        "gate_id": true 
                        "engines_stop_status": true
                        "wheels_chocks_installation_status": true
                        "acu_connection_status": true
                    }
                }
            },

            # Specify the sly data that should come back from the tools to the client.
            # The session is initiated by the tool, and the client must re-use it to continue the conversation.
            "allow": {
                "to_downstream": {
                    "sly_data": {
                        "flight_number": true
                        "aircraft_type": true
                        "flight_status": true
                        "gate_id": true 
                    }
                }
            },
            "tools":    ["acu_operator","trackerAPI","/AirlineTurnaround/aircraft_engines_stop","/AirlineTurnaround/aircraft_chocks_install"]
        },

        {
            "name": "acu_operator",
            "function": {
                "description": """
This agent connects acu to the aircraft and return "acu_connection_status"
                """,
                "parameters": {
                    "type": "object", 
                    "properties": {
                        "flight_number": {
                            "type": "string", 
                            "description": "This is the flight number of the incoming aicraft."
                        },   
                        "aircraft_type": {
                            "type": "string", 
                            "description": "This is the type of the incoming aircraft."
                        },         
                        "flight_status": {
                            "type": "string", 
                            "description": "This is the flight status."
                        },        
                        "gate_id": {
                            "type": "string", 
                            "description": "This is the gate where the aircraft is parked."
                        },         
                        "acu_connection_status": {
                            "type": "string", 
                            "description": "This is the acu connection status."
                        },   
                    }, 
                    "required": ["flight_number", "aircraft_type","flight_status","gate_id"] 
                }
            },
            "class": "aircraft_acu_connect.acu_operator" 
        }, 

#########
        {
            "name": "trackerAPI",
            "function": {

                "description": """
I am the flight tracker in charge of logging parameters during aircraft turnaround. 
I check engines stop status as statusengines_stop_status. 
I check wheels chucks installation status as wheels_chucks_installation_status. 
                """

                "parameters": {
                    "type": "object", 
                    "properties": {
                        "flight_number": {
                            "type": "string", 
                            "description": "This is the flight number of the incoming aicraft."
                        },   
                        "aircraft_type": {
                            "type": "string", 
                            "description": "This is the type of the incoming aircraft."
                        },     
                        "flight_status": {
                            "type": "string", 
                            "description": "This is the flight status."
                        },          
                        "gate_id": {
                            "type": "string", 
                            "description": "This is the gate assigned to the aircraft parking."
                        },     
                        "ground_services_request_type": {
                            "type": "string", 
                            "description": "This is the type of the inquiry received for grand services."
                        },         
                        "wheels_chocks_readiness_status": {
                            "type": "string", 
                            "description": "This is the wheels chocks readiness status."
                        },   
                        "wheels_chocks_installation_status": {
                            "type": "string", 
                            "description": "This is the wheels chocks installation status."
                        },   
                        "gpu_readiness_status": {
                            "type": "string", 
                            "description": "This is the gpu readiness status."
                        },     
                        "acu_connection_status": {
                            "type": "string", 
                            "description": "This is the acu connection status."
                        },     
                        "gpu_connection_status": {
                            "type": "string", 
                            "description": "This is the gpu connection status."
                        },     

                        "engines_stop_status": {
                            "type": "string", 
                            "description": "This is the engines stop status."
                        },    

                        "jetbridge_connection_status": {
                            "type": "string", 
                            "description": "This is the jetbridge connection status."
                        },    

                        "door_opening_status": {
                            "type": "string", 
                            "description": "This is the door opening status."
                        },    
                    }, 
                    // "required": ["flight_number", "aircraft_type","flight_status","assigned_runway_id","gate_id","ground_services_request_type"] 
                }
            },
            "class": "aircraft_acu_connect.trackerAPI" 
        }, 
#########

    ],
}
